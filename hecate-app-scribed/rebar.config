{erl_opts, [debug_info, warnings_as_errors]}.

{deps, [
    {cowboy, "2.12.0"},
    {reckon_db, "1.6.0"},
    {evoq, "1.12.0"},
    {reckon_evoq, "1.5.0"},
    {reckon_gater, "1.3.0"},
    {hecate_sdk, "0.6.1"}
]}.

{relx, [
    {release, {hecate_app_scribed, "0.2.1"}, [
        %% Event sourcing stack
        reckon_db, evoq, reckon_evoq,

        %% Root app — MUST start before domain apps!
        %% hecate_app_scribed_app:start/2 creates documents_store.
        %% Domain apps subscribe to the store in their init/1 callbacks.
        hecate_app_scribed,

        %% Domain apps (subscribe to documents_store)
        guide_document_lifecycle,
        project_documents,
        query_documents,

        sasl
    ]},
    {mode, dev},
    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true},
    {sys_config, "config/sys.config"},
    {vm_args, "config/vm.args"}
]}.

{profiles, [
    {prod, [{relx, [{mode, prod}, {dev_mode, false}, {include_erts, true}]}]},
    {test, [{deps, [{meck, "0.9.2"}]}]}
]}.

{project_plugins, [rebar3_ex_doc]}.
{ex_doc, [
    {source_url, <<"https://github.com/hecate-apps/hecate-app-scribe">>},
    {extras, [<<"README.md">>]},
    {main, <<"README.md">>}
]}.
{hex, [{doc, ex_doc}]}.

{dialyzer, [
    {warnings, [error_handling]},
    {plt_extra_apps, [cowboy, cowlib, ranch, reckon_evoq, evoq, hecate_sdk]},
    {exclude_apps, [reckon_db, reckon_gater, khepri, ra, horus, aten, seshat, gen_batch_server]}
]}.
